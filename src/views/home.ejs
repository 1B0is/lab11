<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home - MyApp</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="navbar-brand">MyApp</a>
      <ul class="navbar-nav">
        <li><a href="/">Home</a></li>
        <% if (locals.user) { %>
          <li><span class="user-info">Welcome, <%= locals.user.email %></span></li>
          <li><a href="/profile">Profile</a></li>
          <li><form method="POST" action="/logout" style="display: inline;"><button type="submit" class="btn btn-secondary" style="padding: 8px 16px; margin: 0;">Logout</button></form></li>
        <% } else { %>
          <li><a href="/login">Login</a></li>
        <% } %>
      </ul>
    </div>
  </nav>

  <div class="container fade-in">
    <div class="page-header">
      <h1>Welcome to MyApp</h1>
      <p>Your secure authentication platform</p>
    </div>

    <div class="home-links">
      <% if (!locals.user) { %>
        <a href="/login">Login</a>
      <% } else { %>
        <a href="/profile">View Profile</a>
      <% } %>
    </div>
  </div>
</body>
</html>

